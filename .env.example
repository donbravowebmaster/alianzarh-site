# =========================================================================
# CONFIGURACIÓN SMTP DE HOSTINGER (ALIANZA RH SITE)
# =========================================================================
# Guarda este archivo como '.env.local' en la raíz del proyecto para uso local.
# NO guardes ni subas el archivo '.env.local' con tus contraseñas reales a Git.
# =========================================================================

# Configuración del servidor de salida de correo
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contacto@alianzarh.com
SMTP_PASS=tu_contrasena_de_correo_aqui

# Dirección a la que llegarán las notificaciones (leads)
NOTIFICATION_RECIPIENT=contacto@alianzarh.com
